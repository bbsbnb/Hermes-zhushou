{
  "manifest_version": 3,
  "name": "工程提示词助手",
  "version": "1.0.0",
  "description": "工程行业提示词管理、复制与AI优化",
  "permissions": [
    "sidePanel",
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}